  <script src="src/index.js"></script>
  <script>
    var MODULE_META = {
      Storage: { type: 'Core', desc: 'localStorage adapter with memory fallback' },
      Security: { type: 'Core', desc: 'Password encoding (btoa, TextEncoder, hex)' },
      Formatters: { type: 'Core', desc: 'Currency, percent, date formatting' },
      DOM: { type: 'Core', desc: 'Safe queries, events, focus trap' },
      Config: { type: 'Config', desc: 'Country indices, tech stocks, API URLs' },
      Spinner: { type: 'Component', desc: 'Loading ring, bar, dots' },
      Modal: { type: 'Component', desc: 'Accessible dialog w/ focus trap' },
      SearchInput: { type: 'Component', desc: 'Debounced search w/ clear button' },
      BottomNav: { type: 'Component', desc: 'Tab navigation w/ badges' },
      Notifications: { type: 'Component', desc: 'Toast notification system' },
      Particles: { type: 'Component', desc: 'Background particle animation' },
      AuthService: { type: 'Service', desc: 'User auth CRUD' },
      WalletService: { type: 'Service', desc: 'Balance, holdings, transactions' },
      MarketService: { type: 'Service', desc: 'CoinGecko + Yahoo Finance' },
      AdminService: { type: 'Service', desc: 'Admin auth, user mgmt, logs' },
      AuthForm: { type: 'Pattern', desc: 'Login/signup with validation' },
      CoinDetail: { type: 'Pattern', desc: 'Coin modal w/ sparkline chart' },
      TradeModal: { type: 'Pattern', desc: 'Buy/sell w/ balance validation' },
      App: { type: 'App', desc: 'Application orchestrator' }
    };

    function log(msg, type) {
      var el = document.getElementById("consoleLog");
      if (!el) return;
      var time = new Date().toLocaleTimeString();
      var div = document.createElement("div");
      div.className = "log-entry";
      var color = type === "ok" ? "#16c784" : type === "err" ? "#ea3943" : "#a0a0c0";
      div.innerHTML = "<span class=\\"time\\">[" + time + "]</span> <span class=\\"data\\" style=\\"color:" + color + "\\">" + msg + "</span>";
      el.appendChild(div);
      el.scrollTop = el.scrollHeight;
    }

    function showAllModules() {
      var grid = document.getElementById("moduleGrid");
      if (!grid) return;
      var mods = LiveMarket ? LiveMarket.list() : [];
      var countEl = document.getElementById("moduleCount");

      if (mods.length === 0) {
        grid.innerHTML = "<div style=\\"grid-column:1/-1;text-align:center;padding:32px;color:#606080\\">No modules detected. Make sure module scripts are loaded.</div>";
        if (countEl) countEl.textContent = "0 modules found";
        return;
      }

      var html = "";
      var typeOrder = { Core: 0, Config: 1, Component: 2, Pattern: 3, Service: 4, App: 5 };
      mods.sort(function(a, b) {
        var ta = MODULE_META[a.id] ? typeOrder[MODULE_META[a.id].type] || 99 : 99;
        var tb = MODULE_META[b.id] ? typeOrder[MODULE_META[b.id].type] || 99 : 99;
        if (ta !== tb) return ta - tb;
        return a.id.localeCompare(b.id);
      });

      for (var i = 0; i < mods.length; i++) {
        var m = mods[i];
        var meta = MODULE_META[m.id] || { type: "Unknown", desc: "" };
        var typeClass = "badge-" + (meta.type === "Core" ? "blue" : meta.type === "Service" ? "green" : meta.type === "Component" ? "yellow" : meta.type === "Pattern" ? "red" : "blue");
        var dotClass = m.available ? "green" : "red";
        html += "<div class=\\"flex\\" style=\\"justify-content:space-between\\"><span class=\\"status-dot " + dotClass + "\\"></span><span class=\\"badge " + typeClass + "\\">" + meta.type + "</span></div>";
        html += "<div class=\\"name\\">" + m.id + "</div>";
        html += "<div class=\\"methods\\">" + m.methods + " methods" + (m.hasInit ? " <span style=\\"color:#16c784\\">(init)</span>" : "") + "</div>";
        html += "<div style=\\"font-size:10px;color:#606080;margin-top:2px\\">" + meta.desc + "</div>";
        html += "</div>";
      }
      grid.innerHTML = html;
      if (countEl) countEl.textContent = mods.length + " modules loaded";

      var status = document.getElementById("globalStatus");
      if (status) {
        var loadedCount = mods.filter(function(m) { return m.available; }).length;
        status.innerHTML = "<span class=\\"status-dot green\\"></span>" + loadedCount + "/" + mods.length + " loaded";
      }
    }

    function showMethods(id) {
      var panel = document.getElementById("methodDetail");
      if (!panel) return;
      var mod = LiveMarket ? LiveMarket.get(id) : null;
      if (!mod) {
        panel.innerHTML = "<p style=\\"color:#ea3943;font-size:13px\\">Module \"" + id + "\" not loaded</p>";
        return;
      }
      var html = "<h3 style=\\"font-size:14px;margin-bottom:8px\\">" + id + " &mdash; Methods</h3>";
      html += "<div class=\\"method-list\\">";
      var keys = Object.keys(mod).sort();
      for (var i = 0; i < keys.length; i++) {
        var k = keys[i];
        var v = mod[k];
        if (typeof v === "function") {
          var str = v.toString();
          var params = str.match(/^\\(?([^)]*)\\)?/) || [""];
          html += "<div><span class=\\"fn\\">" + k + "</span><span class=\\"params\\">(" + params[1] + ")</span></div>";
        } else {
          var val = typeof v === "string" ? v : typeof v === "number" ? v : typeof v;
          html += "<div style=\\"color:#606080\\">" + k + ": " + val + "</div>";
        }
      }
      html += "</div>";
      panel.innerHTML = html;

      // Switch to methods tab
      document.querySelectorAll(".tab-btn").forEach(function(b) { b.classList.remove("active"); });
      document.querySelectorAll("[data-tab=\\"methods\\"]").forEach(function(b) { b.classList.add("active"); });
      document.querySelectorAll(".tab-content").forEach(function(c) { c.classList.remove("active"); });
      document.getElementById("tab-methods").classList.add("active");
    }

    function consoleTest() {
      log("=== Live Market Component Test ===", "ok");
      log("LiveMarket version: " + (LiveMarket ? LiveMarket.version : "N/A"), "ok");

      var storage = LiveMarket ? LiveMarket.get("Storage") : null;
      if (storage) {
        storage.set("test_key", "hello_world");
        var val = storage.get("test_key");
        log("Storage.get/set: worked (val=" + val + ")", "ok");
        storage.remove("test_key");
      } else { log("Storage: not loaded", "err"); }

      var sec = LiveMarket ? LiveMarket.get("Security") : null;
      if (sec) {
        var enc = sec.encode("password123");
        log("Security.encode: " + enc.substring(0, 20) + "...", "ok");
      } else { log("Security: not loaded", "err"); }

      var fmt = LiveMarket ? LiveMarket.get("Formatters") : null;
      if (fmt) {
        log("Formatters.currency(1234.5): " + fmt.currency(1234.5), "ok");
        log("Formatters.percent(0.1234): " + fmt.percent(0.1234), "ok");
      } else { log("Formatters: not loaded", "err"); }

      var dom = LiveMarket ? LiveMarket.get("DOM") : null;
      if (dom) {
        log("DOM.isLoaded: " + dom.isLoaded(), "ok");
      } else { log("DOM: not loaded", "err"); }

      var config = LiveMarket ? LiveMarket.get("Config") : null;
      if (config && config.countries) {
        log("Config.countries: " + config.countries.length + " countries", "ok");
      } else { log("Config: not loaded", "err"); }

      var spinner = LiveMarket ? LiveMarket.get("Spinner") : null;
      if (spinner) {
        log("Spinner API: ring, bar, dots, remove", "ok");
      } else { log("Spinner: not loaded", "err"); }

      var modal = LiveMarket ? LiveMarket.get("Modal") : null;
      if (modal) {
        log("Modal API: open, close, confirm, alert", "ok");
      } else { log("Modal: not loaded", "err"); }

      var authSvc = LiveMarket ? LiveMarket.get("AuthService") : null;
      if (authSvc) {
        log("AuthService API: login, signup, logout", "ok");
        var r = authSvc.signup("test@demo.com", "pass123", "pass123");
        log("  signup test result: " + JSON.stringify(r), r.ok ? "ok" : "err");
      } else { log("AuthService: not loaded", "err"); }

      var wallet = LiveMarket ? LiveMarket.get("WalletService") : null;
      if (wallet) {
        var authSvc2 = LiveMarket ? LiveMarket.get("AuthService") : null;
        if (authSvc2) wallet.init("test_user");
        log("WalletService balance: $" + wallet.getBalance(), "ok");
      } else { log("WalletService: not loaded", "err"); }

      var market = LiveMarket ? LiveMarket.get("MarketService") : null;
      if (market) {
        log("MarketService API: fetchCoins, getSummary, getData", "ok");
      } else { log("MarketService: not loaded", "err"); }

      var admin = LiveMarket ? LiveMarket.get("AdminService") : null;
      if (admin) {
        log("AdminService API: login, blockUser, getStats", "ok");
      } else { log("AdminService: not loaded", "err"); }

      var app = LiveMarket ? LiveMarket.get("App") : null;
      if (app) {
        log("App: loaded, version " + app.version || "1.0.0", "ok");
      } else { log("App: not loaded", "err"); }

      log("=== Component test complete ===", "ok");
      log("Modules scanned: " + (LiveMarket ? LiveMarket.list().length : 0), "ok");
    }

    // Tab switching
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll(".tab-btn").forEach(function(btn) {
        btn.addEventListener("click", function() {
          var tab = this.dataset.tab;
          document.querySelectorAll(".tab-btn").forEach(function(b) { b.classList.remove("active"); });
          this.classList.add("active");
          document.querySelectorAll(".tab-content").forEach(function(c) { c.classList.remove("active"); });
          var target = document.getElementById("tab-" + tab);
          if (target) target.classList.add("active");
        });
      });

      // Auto-scan when ready
      function init() {
        if (typeof LiveMarket !== "undefined") {
          showAllModules();
          log("LiveMarket Scripts Hub initialized", "ok");
          log("LiveMarket v" + LiveMarket.version + " - " + LiveMarket.list().length + " modules scanned", "ok");
        } else {
          setTimeout(init, 200);
        }
      }
      init();
    });
  </script>
